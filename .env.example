# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs of bot admins (lab managers)
ADMIN_IDS=

# IANA timezone used for displaying times to users (e.g. Asia/Tehran, UTC)
TZ=UTC

# Public HTTPS URL the Mini App is served at (e.g. a Cloudflare Tunnel / ngrok URL, or your
# real domain once one is set up). Telegram requires a valid HTTPS URL to open a Mini App.
WEBAPP_PUBLIC_URL=
