# Signs/verifies the web UI's login session tokens -- keep this secret and stable (rotating it
# invalidates every logged-in session). Generate one with e.g. `openssl rand -hex 32`.
WEB_JWT_SECRET=

# Bootstrap web admin, seeded once on first startup. Existing accounts are left untouched on
# later restarts even if you change these.
WEB_ADMIN_USERNAME=
WEB_ADMIN_PASSWORD=

# IANA timezone used for displaying times to users (e.g. Asia/Tehran, UTC)
TZ=UTC
