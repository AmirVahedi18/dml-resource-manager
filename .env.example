# --- interface.mode=bot -------------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs of bot admins (lab managers)
ADMIN_IDS=

# --- interface.mode=web --------------------------------------------------------------------

# Signs/verifies the web UI's login session tokens -- keep this secret and stable (rotating it
# invalidates every logged-in session). Generate one with e.g. `openssl rand -hex 32`.
WEB_JWT_SECRET=

# Bootstrap web admin, seeded once on first startup (mirrors ADMIN_IDS' role for the bot -- see
# README). Existing accounts are left untouched on later restarts even if you change these.
WEB_ADMIN_USERNAME=
WEB_ADMIN_PASSWORD=

# --- shared ----------------------------------------------------------------------------------

# IANA timezone used for displaying times to users (e.g. Asia/Tehran, UTC)
TZ=UTC
